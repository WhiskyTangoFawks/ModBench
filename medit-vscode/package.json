{
  "name": "medit-vscode",
  "displayName": "Modbench",
  "description": "Modbench: install, order, and deploy mods; view, edit, and compare Bethesda plugin files (.esp/.esm/.esl)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Modbench",
      "properties": {
        "modbench.backendPort": {
          "type": "number",
          "default": 5172,
          "description": "Port the mEdit backend API listens on."
        },
        "modbench.game.dataFolderPath": {
          "type": "string",
          "default": "",
          "description": "Override: absolute path to the Fallout 4 Data folder. Leave blank for auto-detect."
        },
        "modbench.game.pluginsTxtPath": {
          "type": "string",
          "default": "",
          "description": "Override: absolute path to Plugins.txt. Leave blank for auto-detect."
        },
        "modbench.scriptsPath": {
          "type": "string",
          "default": "",
          "description": "Path to folder containing .sql filter files and .py scripts. Defaults to ~/.medit/scripts."
        },
        "modbench.mods.gameDirectory": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Game directory to deploy into (the folder containing the game executable and Data/). A Steam install or a stock game folder. Leave blank to fall back to ModOrganizer.ini's gamePath, then Steam auto-detect."
        },
        "modbench.mods.deploymentMode": {
          "type": "string",
          "enum": [
            "standalone",
            "external"
          ],
          "enumDescriptions": [
            "Modbench hardlinks the merged mod view into the game directory's Data/ (the mechanism on Linux, where MO2's USVFS is unavailable).",
            "An external manager (MO2/Vortex) owns deployment; Modbench hides Deploy/Purge/Launch Game."
          ],
          "default": "standalone",
          "scope": "resource",
          "description": "Who deploys mods into the game directory."
        },
        "modbench.mods.launchCommand": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Optional override for Launch Game. Template with a ${executable} placeholder (e.g. for Proton/Wine or an F4SE loader). Leave blank to spawn the executable directly."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "modbench",
          "title": "Modbench",
          "icon": "images/medit.svg"
        }
      ]
    },
    "views": {
      "modbench": [
        {
          "id": "modbench.modList",
          "name": "Mods",
          "when": "modbench.viewMode == 'loadout'"
        },
        {
          "id": "modbench.pluginTree",
          "name": "Plugins",
          "when": "modbench.viewMode == 'editing'"
        },
        {
          "id": "modbench.changeGroupTree",
          "name": "Change Groups",
          "when": "modbench.viewMode == 'editing'"
        }
      ]
    },
    "commands": [
      {
        "command": "modbench.openEditor",
        "title": "Modbench: Open Editor"
      },
      {
        "command": "modbench.openCompare",
        "title": "Modbench: Open Compare"
      },
      {
        "command": "modbench.reloadSession",
        "title": "Modbench: Reload Session"
      },
      {
        "command": "modbench.refreshTree",
        "title": "Modbench: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "modbench.newPlugin",
        "title": "Modbench: New Plugin…",
        "icon": "$(add)"
      },
      {
        "command": "modbench.copyAsOverrideInto",
        "title": "Modbench: Copy as Override Into…"
      },
      {
        "command": "modbench.setFilter",
        "title": "Modbench: Filter Records…",
        "icon": "$(filter)"
      },
      {
        "command": "modbench.clearFilter",
        "title": "Modbench: Clear Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "modbench.setFilterFromDocument",
        "title": "Modbench: Apply SQL File as Filter"
      },
      {
        "command": "modbench.showReferencedBy",
        "title": "Modbench: Show Referenced By"
      },
      {
        "command": "modbench.deleteRecord",
        "title": "Modbench: Delete Record"
      },
      {
        "command": "modbench.createPlaced",
        "title": "Modbench: Create Placed…"
      },
      {
        "command": "modbench.saveGroup",
        "title": "Modbench: Save Group",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "modbench.revertGroup",
        "title": "Modbench: Revert Group",
        "icon": "$(discard)"
      },
      {
        "command": "modbench.saveAllGroups",
        "title": "Modbench: Save All Groups",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "modbench.revertAllGroups",
        "title": "Modbench: Revert All Groups",
        "icon": "$(discard)"
      },
      {
        "command": "modbench.modList.filter",
        "title": "Modbench: Filter Mods…",
        "icon": "$(search)"
      },
      {
        "command": "modbench.modList.switchProfile",
        "title": "Modbench: Switch Profile…",
        "icon": "$(account)"
      },
      {
        "command": "modbench.modList.launchMedit",
        "title": "Modbench: Launch mEdit",
        "icon": "$(rocket)"
      },
      {
        "command": "modbench.closeMedit",
        "title": "Modbench: Close mEdit",
        "icon": "$(close)"
      },
      {
        "command": "modbench.modList.refresh",
        "title": "Modbench: Refresh Mod List",
        "icon": "$(refresh)"
      },
      {
        "command": "modbench.modList.deploy",
        "title": "Modbench: Deploy Mods",
        "icon": "$(cloud-download)"
      },
      {
        "command": "modbench.modList.purge",
        "title": "Modbench: Purge Deployed Mods",
        "icon": "$(clear-all)"
      },
      {
        "command": "modbench.modList.launchGame",
        "title": "Modbench: Launch Game",
        "icon": "$(run-all)"
      },
      {
        "command": "modbench.modList.installFromArchive",
        "title": "Modbench: Install Mod from Archive…"
      },
      {
        "command": "modbench.modList.installFromFolder",
        "title": "Modbench: Install Mod from Folder…"
      },
      {
        "command": "modbench.modList.mod.openInExplorer",
        "title": "Open in Explorer"
      },
      {
        "command": "modbench.modList.mod.addSeparatorBelow",
        "title": "Add Separator Below…"
      },
      {
        "command": "modbench.modList.mod.moveToSeparator",
        "title": "Move to Separator…"
      },
      {
        "command": "modbench.modList.mod.uninstall",
        "title": "Uninstall…"
      },
      {
        "command": "modbench.modList.mod.viewOnNexus",
        "title": "View on Nexus Mods"
      },
      {
        "command": "modbench.modList.separator.rename",
        "title": "Rename…"
      },
      {
        "command": "modbench.modList.separator.addSeparatorBelow",
        "title": "Add Separator Below…"
      },
      {
        "command": "modbench.modList.separator.delete",
        "title": "Delete Separator"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "modbench.refreshTree",
          "when": "view == modbench.pluginTree",
          "group": "navigation"
        },
        {
          "command": "modbench.closeMedit",
          "when": "view == modbench.pluginTree",
          "group": "navigation@9"
        },
        {
          "command": "modbench.newPlugin",
          "when": "view == modbench.pluginTree",
          "group": "navigation"
        },
        {
          "command": "modbench.setFilter",
          "when": "view == modbench.pluginTree",
          "group": "navigation"
        },
        {
          "command": "modbench.clearFilter",
          "when": "view == modbench.pluginTree && modbench.filterActive",
          "group": "navigation"
        },
        {
          "command": "modbench.modList.filter",
          "when": "view == modbench.modList",
          "group": "navigation@1"
        },
        {
          "command": "modbench.modList.switchProfile",
          "when": "view == modbench.modList",
          "group": "navigation@2"
        },
        {
          "command": "modbench.modList.launchMedit",
          "when": "view == modbench.modList",
          "group": "navigation@3"
        },
        {
          "command": "modbench.modList.refresh",
          "when": "view == modbench.modList",
          "group": "navigation@4"
        },
        {
          "command": "modbench.modList.deploy",
          "when": "view == modbench.modList && modbench.deploymentStandalone",
          "group": "navigation@5"
        },
        {
          "command": "modbench.modList.purge",
          "when": "view == modbench.modList && modbench.deploymentStandalone",
          "group": "navigation@6"
        },
        {
          "command": "modbench.modList.launchGame",
          "when": "view == modbench.modList && modbench.deploymentStandalone",
          "group": "navigation@7"
        },
        {
          "command": "modbench.saveAllGroups",
          "when": "view == modbench.changeGroupTree",
          "group": "navigation"
        },
        {
          "command": "modbench.revertAllGroups",
          "when": "view == modbench.changeGroupTree",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "modbench.clearFilter",
          "when": "modbench.filterActive",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "modbench.copyAsOverrideInto",
          "when": "view == modbench.pluginTree && viewItem == record",
          "group": "modbench@1"
        },
        {
          "command": "modbench.showReferencedBy",
          "when": "view == modbench.pluginTree && viewItem == record",
          "group": "modbench@2"
        },
        {
          "command": "modbench.deleteRecord",
          "when": "view == modbench.pluginTree && viewItem == record",
          "group": "modbench@3"
        },
        {
          "command": "modbench.createPlaced",
          "when": "view == modbench.pluginTree && (viewItem == placedGroup-persistent || viewItem == placedGroup-temporary)",
          "group": "modbench@1"
        },
        {
          "command": "modbench.copyAsOverrideInto",
          "when": "view == modbench.pluginTree && viewItem == refr",
          "group": "modbench@1"
        },
        {
          "command": "modbench.deleteRecord",
          "when": "view == modbench.pluginTree && viewItem == refr",
          "group": "modbench@2"
        },
        {
          "command": "modbench.saveGroup",
          "when": "view == modbench.changeGroupTree && viewItem == changeGroup",
          "group": "inline"
        },
        {
          "command": "modbench.modList.mod.openInExplorer",
          "when": "view == modbench.modList && viewItem == mod",
          "group": "modActions@1"
        },
        {
          "command": "modbench.modList.mod.addSeparatorBelow",
          "when": "view == modbench.modList && viewItem == mod",
          "group": "modActions@2"
        },
        {
          "command": "modbench.modList.mod.moveToSeparator",
          "when": "view == modbench.modList && viewItem == mod",
          "group": "modActions@3"
        },
        {
          "command": "modbench.modList.mod.uninstall",
          "when": "view == modbench.modList && viewItem == mod",
          "group": "modActions@4"
        },
        {
          "command": "modbench.modList.mod.openInExplorer",
          "when": "view == modbench.modList && viewItem == modWithNexus",
          "group": "modActions@1"
        },
        {
          "command": "modbench.modList.mod.addSeparatorBelow",
          "when": "view == modbench.modList && viewItem == modWithNexus",
          "group": "modActions@2"
        },
        {
          "command": "modbench.modList.mod.moveToSeparator",
          "when": "view == modbench.modList && viewItem == modWithNexus",
          "group": "modActions@3"
        },
        {
          "command": "modbench.modList.mod.uninstall",
          "when": "view == modbench.modList && viewItem == modWithNexus",
          "group": "modActions@4"
        },
        {
          "command": "modbench.modList.mod.viewOnNexus",
          "when": "view == modbench.modList && viewItem == modWithNexus",
          "group": "modActions@5"
        },
        {
          "command": "modbench.modList.separator.rename",
          "when": "view == modbench.modList && viewItem == separator",
          "group": "sepActions@1"
        },
        {
          "command": "modbench.modList.separator.addSeparatorBelow",
          "when": "view == modbench.modList && viewItem == separator",
          "group": "sepActions@2"
        },
        {
          "command": "modbench.modList.separator.delete",
          "when": "view == modbench.modList && viewItem == separator",
          "group": "sepActions@3"
        },
        {
          "command": "modbench.revertGroup",
          "when": "view == modbench.changeGroupTree && viewItem == changeGroup",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "modbench.deleteRecord",
        "key": "Delete",
        "when": "focusedView == modbench.pluginTree && viewItem == record"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run build:backend",
    "build": "tsc -p tsconfig.json --noEmit && node esbuild.mjs && npm run build:webview",
    "build:webview": "VITE_CJS_IGNORE_WARNING=1 vite build --config webview/vite.config.ts",
    "build:backend": "dotnet publish ../MEditService/MEditService.Api/MEditService.Api.csproj -c Release --self-contained -r linux-x64 -o backend",
    "watch": "node esbuild.mjs --watch",
    "generate-api": "openapi-typescript http://localhost:5172/swagger/v1/swagger.json -o src/generated/api.ts",
    "test:unit": "vitest run",
    "test:integration": "tsc -p tsconfig.integration.json && vscode-test",
    "lint": "eslint src webview/src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
